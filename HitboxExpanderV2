local _G_Enabled = false
local SelectedPlayer = "Tất cả"
local currentSize = 20
local originalSizes = {}
local targets = {}
local frameCounter = 0
local FRAME_SKIP = 3
local WARN_THRESHOLD = 500

local function rebuildTargets()
    table.clear(targets)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and (SelectedPlayer == "Tất cả" or SelectedPlayer == player.Name) then
            table.insert(targets, player)
        end
    end
end

local function safeApplySize(player)
    local success, err = pcall(function()
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if not originalSizes[player] then
            originalSizes[player] = root.Size
        end
        local newSize = Vector3.new(currentSize, currentSize, currentSize)
        if root.Size ~= newSize then
            root.Size = newSize
        end
    end)
    if not success then
        warn("ApplySize failed for " .. player.Name .. ": " .. tostring(err))
    end
end

local function safeResetPlayer(player)
    local success, err = pcall(function()
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if originalSizes[player] then
            root.Size = originalSizes[player]
            originalSizes[player] = nil
        end
    end)
    if not success then
        warn("ResetSize failed for " .. player.Name .. ": " .. tostring(err))
    end
end

local heartbeatConnection

local function startHeartbeat()
    if heartbeatConnection then return end
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        frameCounter = frameCounter + 1
        if frameCounter % FRAME_SKIP ~= 0 then return end
        for _, player in ipairs(targets) do
            safeApplySize(player)
        end
    end)
end

local function stopHeartbeat()
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
        heartbeatConnection = nil
    end
end

local function updateState()
    if _G_Enabled then
        rebuildTargets()
        startHeartbeat()
    else
        stopHeartbeat()
        for _, player in ipairs(targets) do
            safeResetPlayer(player)
        end
        table.clear(targets)
    end
end

local function updateToggleVisuals()
    ToggleBtn.Text = _G_Enabled and "ON" or "OFF"
    ToggleBtn.BackgroundColor3 = _G_Enabled and Color3.fromRGB(220, 50, 50) or Color3.fromRGB(0, 170, 120)
    QuickToggleBtn.BackgroundColor3 = ToggleBtn.BackgroundColor3
end

local function updateAlert(value)
    if value > WARN_THRESHOLD then
        AlertLabel.Text = "⚠️ Large size may cause lag!"
        AlertLabel.Visible = true
    else
        AlertLabel.Text = ""
        AlertLabel.Visible = false
    end
end

local function setSizeManually(val)
    val = tonumber(val)
    if not val then return end
    val = math.max(1, val)
    currentSize = val
    SizeSlider.Text = tostring(val)
    updateAlert(val)
    if _G_Enabled then
        for _, player in ipairs(targets) do
            safeApplySize(player)
        end
    end
end

SizeSlider.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        setSizeManually(SizeSlider.Text)
    end
end)

ToggleBtn.MouseButton1Click:Connect(function()
    _G_Enabled = not _G_Enabled
    updateToggleVisuals()
    updateState()
end)

QuickToggleBtn.MouseButton1Click:Connect(function()
    _G_Enabled = not _G_Enabled
    updateToggleVisuals()
    updateState()
end)

