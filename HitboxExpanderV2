local function RefreshList()
    for _, child in ipairs(PlayerList:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    local function createEntry(name)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -8, 0, 26)
        btn.Text = name
        btn.BackgroundColor3 = (SelectedPlayer == name) and Color3.fromRGB(0, 140, 255) or Color3.fromRGB(45, 45, 45)
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 12
        btn.Parent = PlayerList
        local BtnCorner = Instance.new("UICorner", btn)
        BtnCorner.CornerRadius = UDim.new(0, 6)
        btn.MouseButton1Click:Connect(function()
            SelectedPlayer = name
            RefreshList()
            if _G_Enabled then
                for _, player in ipairs(targets) do
                    safeResetPlayer(player)
                end
                rebuildTargets()
                for _, player in ipairs(targets) do
                    safeApplySize(player)
                end
            end
        end)
    end
    createEntry("Tất cả")
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            createEntry(p.Name)
        end
    end
    local buttonCount = 0
    for _ in ipairs(PlayerList:GetChildren()) do buttonCount = buttonCount + 1 end
    PlayerList.CanvasSize = UDim2.new(0, 0, 0, buttonCount * 29 + 6)
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        if not _G_Enabled then return end
        if SelectedPlayer == "Tất cả" or SelectedPlayer == player.Name then
            if not table.find(targets, player) then
                table.insert(targets, player)
            end
            safeApplySize(player)
        end
    end)
    RefreshList()
end)

Players.PlayerRemoving:Connect(function(player)
    safeResetPlayer(player)
    local idx = table.find(targets, player)
    if idx then
        table.remove(targets, idx)
    end
    RefreshList()
end)

RefreshList()
