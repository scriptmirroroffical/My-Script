-- --- FUNCTIONAL LOGIC ---
local function applySleep(rotation)
    isMad = false -- Disable mad state if a fixed posture is chosen
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    
    hum.PlatformStand = false
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
    
    task.wait(0.05)
    
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
    hum.PlatformStand = true
    root.CFrame = root.CFrame * rotation
    lying = true
end

local function standUp()
    isMad = false -- Stop the Mad loop
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    
    hum.PlatformStand = false
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    lying = false
end

local function makeMeMad()
    if isMad then return end -- Prevent multiple loops from running at the same time
    isMad = true
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then isMad = false return end
    
    hum.PlatformStand = true
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
    lying = true
    
    task.spawn(function()
        while isMad do
            if not root or not root.Parent then break end
            
            -- Pick a random angle
            local randomRot = rotations[math.random(1, #rotations)]
            
            -- Lock current Position and apply the new random angle
            root.CFrame = CFrame.new(root.Position) * randomRot
            
            -- Light Fling Mechanics: 
            -- Apply chaotic rotational velocity to fling others upon touch
            root.AssemblyAngularVelocity = Vector3.new(math.random(-500, 500), math.random(-500, 500), math.random(-500, 500))
            
            -- Add slight X/Z movement for unpredictability, but force Y (vertical) to be negative so you don't fly away
            root.AssemblyLinearVelocity = Vector3.new(math.random(-25, 25), -50, math.random(-25, 25))
            
            task.wait() -- Run as fast as the engine allows for smooth physics updates
        end
    end)
end

