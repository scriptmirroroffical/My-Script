    if not hum or not root then isMad = false return end
    
    hum.PlatformStand = true
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
    lying = true
    
    task.spawn(function()
        while isMad do
            if not root or not root.Parent then break end
            local randomRot = rotations[math.random(1, #rotations)]
            root.CFrame = CFrame.new(root.Position) * randomRot
            root.AssemblyAngularVelocity = Vector3.new(math.random(-300, 300), math.random(-300, 300), math.random(-300, 300))
            root.AssemblyLinearVelocity = Vector3.new(math.random(-20, 20), -30, math.random(-20, 20))
            task.wait()
        end
    end)
end

