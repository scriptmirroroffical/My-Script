-- [[ OMNI-GOD CHAMS CORE ]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local ESP_SETTINGS = {
    Enabled = false,
    FillTransparency = 0.5, -- Độ trong suốt của màu thân
    OutlineTransparency = 0, -- Độ trong suốt của viền
}

-- Hàm tạo Highlight (giống trong hình) và Text
local function CreateESP(player)
    local function ApplyESP(character)
        -- 1. Tạo Highlight (Hiệu ứng phủ màu như ảnh)
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "OmniHighlight"
        Highlight.Parent = character
        Highlight.FillTransparency = ESP_SETTINGS.FillTransparency
        Highlight.OutlineTransparency = ESP_SETTINGS.OutlineTransparency
        Highlight.Adornee = character
        Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- Nhìn xuyên tường

        -- 2. Tạo BillboardGui (Hiện tên, team, studs)
        local Billboard = Instance.new("BillboardGui")
        Billboard.Name = "OmniTag"
        Billboard.Size = UDim2.new(0, 200, 0, 50)
        Billboard.StudsOffset = Vector3.new(0, 3, 0) -- Hiển thị trên đầu
        Billboard.AlwaysOnTop = true
        Billboard.Parent = character:WaitForChild("HumanoidRootPart")

        local TextLabel = Instance.new("TextLabel")
        TextLabel.Size = UDim2.new(1, 0, 1, 0)
        TextLabel.BackgroundTransparency = 1
        TextLabel.TextStrokeTransparency = 0
        TextLabel.Font = Enum.Font.SourceSansBold
        TextLabel.TextSize = 14
        TextLabel.Parent = Billboard

        -- Cập nhật logic liên tục
        local Connection
        Connection = RunService.RenderStepped:Connect(function()
            if character and character.Parent and player.Parent then
                local IsEnabled = ESP_SETTINGS.Enabled and player ~= LocalPlayer
                Highlight.Enabled = IsEnabled
                Billboard.Enabled = IsEnabled

                if IsEnabled then
                    -- Cập nhật màu theo Team
                    local teamColor = player.TeamColor.Color
                    Highlight.FillColor = teamColor
                    Highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Viền trắng cho rõ
                    
                    -- Cập nhật văn bản
                    local dist = math.floor((LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - character.HumanoidRootPart.Position).Magnitude) or 0)
                    TextLabel.Text = string.format("%s [%s]\n%d studs", player.Name, (player.Team and player.Team.Name or "No Team"), dist)
                    TextLabel.TextColor3 = teamColor
                end
            else
                Connection:Disconnect()
            end
        end)
    end

    if player.Character then ApplyESP(player.Character) end
    player.CharacterAdded:Connect(ApplyESP)
end

-- Khởi tạo
for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

