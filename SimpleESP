local function makeDraggable(gui)
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil
    
    local function update(input)
        local delta = input.Position - dragStart
        gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            update(dragInput)
        end
    end)
end
makeDraggable(Frame)

local ESP_SETTINGS = {
    Enabled = false,
    FillTransparency = 0.4,
    OutlineTransparency = 0,
}

local function CreateESP(player)
    local function ApplyESP(character)
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "OmniHL"
        Highlight.Parent = character
        Highlight.FillTransparency = ESP_SETTINGS.FillTransparency
        Highlight.OutlineTransparency = ESP_SETTINGS.OutlineTransparency
        Highlight.Adornee = character
        Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        local Billboard = Instance.new("BillboardGui")
        Billboard.Name = "OmniTag"
        Billboard.Size = UDim2.new(0, 120, 0, 28)
        Billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        Billboard.AlwaysOnTop = true
        Billboard.Parent = character:WaitForChild("HumanoidRootPart")
        
        local TextLabel = Instance.new("TextLabel")
        TextLabel.Size = UDim2.new(1, 0, 1, 0)
        TextLabel.BackgroundTransparency = 1
        TextLabel.TextStrokeTransparency = 0
        TextLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        TextLabel.Font = Enum.Font.GothamMedium
        TextLabel.TextSize = 11
        TextLabel.TextScaled = true
        TextLabel.Parent = Billboard
        
        local Connection
        Connection = RunService.RenderStepped:Connect(function()
            if character and character.Parent and player.Parent then
                local IsEnabled = ESP_SETTINGS.Enabled and player ~= LocalPlayer
                Highlight.Enabled = IsEnabled
                Billboard.Enabled = IsEnabled
                
                if IsEnabled then
                    local teamColor = player.TeamColor.Color or Color3.fromRGB(255, 255, 255)
                    Highlight.FillColor = teamColor
                    Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    local dist = "?"
                    if hrp and LocalPlayer.Character then
                        local lhrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if lhrp then
                            dist = math.floor((lhrp.Position - hrp.Position).Magnitude)
                        end
                    end
                    TextLabel.Text = player.Name .. "\n" .. dist .. "m"
                    TextLabel.TextColor3 = teamColor
                end
            else
                Connection:Disconnect()
            end
        end)
    end
    
    if player.Character then ApplyESP(player.Character) end
    player.CharacterAdded:Connect(ApplyESP)
end

for _, p in pairs(Players:GetPlayers()) do 
    if p ~= LocalPlayer then
        CreateESP(p) 
    end
end
Players.PlayerAdded:Connect(function(p)
